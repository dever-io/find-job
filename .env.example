# ── Telegram ─────────────────────────────────────────────
# Токен бота от @BotFather
BOT_TOKEN=

# ── OpenRouter (ИИ-проверка вакансий) ────────────────────
# Ключ с https://openrouter.ai/keys. Если пусто — бот работает на эвристике
# (совпадение по ключевым словам) без ИИ.
OPENROUTER_API_KEY=

# Бесплатные модели для тарифа «Базовый» (перебираются по очереди при сбое).
# Берите ТОЛЬКО instruct-модели (не reasoning: gpt-oss/nemotron-reasoning отдают
# пустой content). Список бесплатных моделей меняется — актуальные см. на
# openrouter.ai/models (фильтр Free). Бесплатный пул часто отдаёт 429 —
# тогда бот падает в эвристику (совпадение по ключевым словам).
OPENROUTER_FREE_MODELS=meta-llama/llama-3.3-70b-instruct:free,google/gemma-4-31b-it:free,google/gemma-4-26b-a4b-it:free,qwen/qwen3-next-80b-a3b-instruct:free,nousresearch/hermes-3-llama-3.1-405b:free,meta-llama/llama-3.2-3b-instruct:free

# Платная модель для тарифа «Про»
OPENROUTER_PRO_MODEL=qwen/qwen3-32b

# ── Тарифы (Telegram Stars за 30-дневный период) ─────────
# 30⭐/мес ≈ 1⭐/день. Потолок Telegram для подписок — 10000⭐.
BASIC_PRICE_STARS=30
# 3000⭐/мес ≈ 100⭐/день
PRO_PRICE_STARS=3000

# ── Ежедневная рассылка ──────────────────────────────────
# Cron-выражение и таймзона (по умолчанию — каждый день в 09:00 по Москве)
CRON_EXPR=0 9 * * *
CRON_TZ=Europe/Moscow

# ── HeadHunter ───────────────────────────────────────────
# api.hh.ru гео-блокирует зарубежные серверные IP (отдаёт 403). Если деплой
# вне России — заверни запросы через собственный RU-прокси и укажи его здесь.
HH_API_BASE=https://api.hh.ru
# HH рекомендует User-Agent вида "AppName/version (contact-email)"
HH_USER_AGENT=StarJobs/0.1 (starjobs-bot@example.com)

# ── Прочее ───────────────────────────────────────────────
DATA_DIR=./data
# ID администратора (опционально)
ADMIN_ID=
# Порог релевантности 0..100: вакансии ниже отбрасываются
SCORE_THRESHOLD=60
# Сколько вакансий проверять ИИ за прогон
CANDIDATES=18
# Максимум вакансий в дневной выдаче
MAX_MATCHES=8
# Параллелизм ИИ-проверки
VERIFY_CONCURRENCY=4
