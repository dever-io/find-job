# ── Telegram ─────────────────────────────────────────────
# Токен бота от @BotFather
BOT_TOKEN=
# Твой Telegram user id — единственный, кому бот подчиняется.
# Узнать: напиши @userinfobot. Если пусто — бот отвечает всем (небезопасно).
OWNER_ID=

# Группа и топики привязываются в рантайме командой /bind внутри топика —
# в .env их указывать НЕ нужно (хранятся в data/store.json).

# ── OpenRouter (ИИ) ──────────────────────────────────────
# Ключ с https://openrouter.ai/keys. Если пусто — бот работает на эвристике
# (совпадение по ключевым словам) без ИИ.
OPENROUTER_API_KEY=

# Модели для скоринга вакансий (перебираются по очереди при сбое). Берите
# instruct-модели (reasoning-модели отдают пустой content). Список бесплатных
# моделей меняется — см. openrouter.ai/models (фильтр Free).
OPENROUTER_SCORE_MODELS=deepseek/deepseek-chat-v3-0324:free,meta-llama/llama-3.3-70b-instruct:free,google/gemini-2.0-flash-exp:free,qwen/qwen-2.5-72b-instruct:free

# Сильная модель для генерации сопроводительных писем (не free-tier).
LETTER_MODEL=deepseek/deepseek-v4-pro

# ── Расписание ───────────────────────────────────────────
# Ежедневный поиск (по умолчанию 09:00 МСК)
CRON_EXPR=0 9 * * *
CRON_TZ=Europe/Moscow
# Частый скан «горячих» вакансий — постятся сразу, вне расписания (по умолчанию каждый час в :15)
HOT_CRON_EXPR=15 * * * *
# Еженедельный дайджест (по умолчанию понедельник 10:00)
DIGEST_CRON_EXPR=0 10 * * 1

# ── HeadHunter ───────────────────────────────────────────
# api.hh.ru гео-блокирует зарубежные серверные IP (403). Деплой вне РФ (Fly и т.п.) —
# заверни запросы через RU-прокси (см. papку proxy/) и укажи его здесь, напр. http://<IP>:8088
HH_API_BASE=https://api.hh.ru
# Секрет X-Proxy-Key для RU-прокси (тот же, что в proxy/.env). Пусто = ходим напрямую.
HH_PROXY_KEY=
# HH рекомендует User-Agent вида "AppName/version (contact-email)".
# ВАЖНО: HH банит плейсхолдеры (example.com/test) → 400 bad_user_agent. Указывай РЕАЛЬНЫЙ контакт.
HH_USER_AGENT=CareerAgent/0.2 (d.alxndrov@gmail.com)
# Access token приложения HH (dev.hh.ru/admin). Авторизованный доступ обходит
# блокировку анонимных дата-центровых IP (Selectel/облака). Настоятельно рекомендуется.
HH_ACCESS_TOKEN=

# ── Прочее ───────────────────────────────────────────────
DATA_DIR=./data
# Порог релевантности 0..100: вакансии ниже отбрасываются
SCORE_THRESHOLD=60
# Сколько вакансий проверять ИИ за прогон
CANDIDATES=18
# Максимум вакансий в выдаче за прогон (на трек)
MAX_MATCHES=8
# Параллелизм ИИ-проверки
VERIFY_CONCURRENCY=4
