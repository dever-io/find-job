{
  "name": "ai-career-agent",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "AI Career Agent — личный Telegram-агент поиска работы: ищет вакансии по двум трекам, оценивает через ИИ (OpenRouter) и постит в топики группы",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "grammy": "^1.30.0",
    "node-cron": "^3.0.3",
    "pdf-parse": "^1.1.1",
    "socks-proxy-agent": "^10.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
