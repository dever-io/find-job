{
  "name": "telegram-jobs-bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "StarJobs — Telegram-бот, который за звёзды в день ищет работу по всей России и проверяет вакансии через ИИ (OpenRouter)",
  "license": "MIT",
  "author": "Grigorij Dubrovskih <gri.dubrovskih@gmail.com>",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "try:search": "tsx src/scripts/try-search.ts",
    "try:bot": "tsx src/scripts/try-bot.ts"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "grammy": "^1.30.0",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
